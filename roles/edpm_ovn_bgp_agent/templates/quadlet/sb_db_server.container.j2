# Quadlet container file for sb_db_server
# Managed by edpm_container_standalone - do not edit manually
# Requires Podman 4.6+ (RHEL 9.4+)
{%- set _sb_db_volumes = [] -%}
{%- set _sb_db_volumes = _sb_db_volumes
    + edpm_ovn_bgp_agent_local_ovn_cluster_common_volumes
    + edpm_ovn_bgp_agent_local_ovn_sb_volumes
    + edpm_ovn_bgp_agent_local_ovn_cluster_tls_cacert_volumes -%}
{%- if edpm_enable_internal_tls | bool -%}
{%- set _sb_db_volumes = _sb_db_volumes
    + edpm_ovn_bgp_agent_local_ovn_cluster_tls_volumes -%}
{%- endif %}

# DO NOT REMOVE - used by container_config_hash module
# config_hash=

[Unit]
Description=OVN SB DB Server container (EDPM OVN BGP Agent)
After=openvswitch.service
Requires=openvswitch.service

[Container]
ContainerName=sb_db_server
Image={{ edpm_ovn_bgp_agent_local_ovn_sb_db_image }}
Network=host
User=root
PodmanArgs=--privileged
{% if edpm_ovn_cpu_set | default(false) -%}
PodmanArgs=--cpuset-cpus={{ edpm_ovn_cpu_set }}
{% endif -%}
LogDriver=journald
Environment=KOLLA_CONFIG_STRATEGY=COPY_ALWAYS
{% for vol in _sb_db_volumes -%}
Volume={{ vol }}
{% endfor -%}
Label=managed_by=edpm_ansible

[Service]
Restart=always
TimeoutStartSec=900
TimeoutStopSec=84

[Install]
WantedBy=multi-user.target
