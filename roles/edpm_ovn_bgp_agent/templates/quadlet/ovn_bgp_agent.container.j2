# Quadlet container file for ovn_bgp_agent
# Managed by edpm_container_standalone - do not edit manually
# Requires Podman 4.6+ (RHEL 9.4+)
{%- set _ovn_bgp_agent_volumes = [] -%}
{%- set _ovn_bgp_agent_volumes = _ovn_bgp_agent_volumes
    + edpm_ovn_bgp_agent_common_volumes
    + edpm_ovn_bgp_agent_tls_cacert_volumes -%}
{%- if edpm_ovn_bgp_agent_local_ovn_routing | bool -%}
{%- set _ovn_bgp_agent_volumes = _ovn_bgp_agent_volumes
    + edpm_ovn_bgp_agent_local_ovn_cluster_common_volumes -%}
{%- endif -%}
{%- if edpm_ovn_bgp_agent_internal_tls_enable | bool -%}
{%- set _ovn_bgp_agent_volumes = _ovn_bgp_agent_volumes
    + edpm_ovn_bgp_agent_tls_volumes -%}
{%- endif %}

# DO NOT REMOVE - used by container_config_hash module
# config_hash=

[Unit]
Description=OVN BGP Agent container (EDPM)
After=openvswitch.service
Requires=openvswitch.service
PartOf=edpm_frr.service

[Container]
ContainerName=ovn_bgp_agent
Image={{ edpm_ovn_bgp_agent_image }}
Network=host
User=root
PodmanArgs=--privileged
LogDriver=journald
Environment=KOLLA_CONFIG_STRATEGY=COPY_ALWAYS
{% for vol in _ovn_bgp_agent_volumes -%}
Volume={{ vol }}
{% endfor -%}
Label=managed_by=edpm_ansible

[Service]
Restart=always
TimeoutStartSec=900
TimeoutStopSec=84

[Install]
WantedBy=multi-user.target
