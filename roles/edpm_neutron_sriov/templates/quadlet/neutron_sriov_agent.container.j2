# Quadlet container file for neutron_sriov_agent
# Managed by edpm_container_standalone - do not edit manually
# Requires Podman 4.6+ (RHEL 9.4+)
{%- set _sriov_volumes = [] -%}
{%- set _sriov_volumes = _sriov_volumes
    + edpm_neutron_sriov_common_volumes
    + edpm_neutron_sriov_tls_cacert_volumes %}

# DO NOT REMOVE - used by container_config_hash module
# config_hash=

[Unit]
Description=Neutron SR-IOV Agent container (EDPM)

[Container]
ContainerName=neutron_sriov_agent
Image={{ edpm_neutron_sriov_image }}
Network=host
User=neutron
PodmanArgs=--privileged
LogDriver=journald
Environment=KOLLA_CONFIG_STRATEGY=COPY_ALWAYS
{% for vol in _sriov_volumes -%}
Volume={{ vol }}
{% endfor -%}
Label=managed_by=edpm_ansible

[Service]
Restart=always
TimeoutStartSec=900
TimeoutStopSec=84

[Install]
WantedBy=multi-user.target
