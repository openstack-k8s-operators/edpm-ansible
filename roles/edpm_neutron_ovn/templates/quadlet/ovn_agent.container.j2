# Quadlet container file for ovn_agent
# Managed by edpm_container_standalone - do not edit manually
# Requires Podman 4.6+ (RHEL 9.4+)
{%- set _ovn_agent_volumes = [] -%}
{%- set _ovn_agent_volumes = _ovn_agent_volumes
    + edpm_neutron_ovn_common_volumes
    + edpm_neutron_ovn_tls_cacert_volumes -%}
{%- if edpm_neutron_ovn_tls_enabled | bool -%}
{%- set _ovn_agent_volumes = _ovn_agent_volumes
    + edpm_neutron_ovn_tls_volumes -%}
{%- endif %}

# DO NOT REMOVE - used by container_config_hash module
# config_hash=

[Unit]
Description=Neutron OVN Agent container (EDPM)
After=openvswitch.service
Requires=openvswitch.service

[Container]
ContainerName=ovn_agent
Image={{ edpm_neutron_ovn_agent_image }}
Network=host
User=root
PodmanArgs=--privileged
PodmanArgs=--pid=host
PodmanArgs=--cgroupns=host
LogDriver=journald
Environment=KOLLA_CONFIG_STRATEGY=COPY_ALWAYS
{% for vol in _ovn_agent_volumes -%}
Volume={{ vol }}
{% endfor -%}
Label=managed_by=edpm_ansible

[Service]
Restart=always
TimeoutStartSec=900
TimeoutStopSec=84

[Install]
WantedBy=multi-user.target
